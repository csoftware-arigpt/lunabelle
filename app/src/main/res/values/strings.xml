    <!-- Disclaimers -->
    <string name="disclaimer_title">Before you start</string>
    <string name="disclaimer_contra_title">Not a contraceptive</string>
    <string name="disclaimer_contra_body">This app is for tracking and information only. It is not a contraceptive method and must not be used to prevent pregnancy. Calendar-based prediction is unreliable for birth control (roughly 20 to 24 of every 100 people relying on it become pregnant within a year). Use a proven method and talk to a healthcare professional</string>
    <string name="disclaimer_estimates_title">Estimates only</string>
    <string name="disclaimer_estimates_body">All predictions (next period, ovulation, fertile window) are estimates based on your logged history and population averages, not measurements. Accuracy improves after several cycles. Ovulation is especially variable; confirm with LH tests, basal body temperature, or cervical mucus</string>
    <string name="disclaimer_clinician_title">Consult a clinician</string>
    <string name="disclaimer_clinician_body">This app does not provide medical advice and cannot diagnose or treat any condition. If you notice cycles shorter than 21 or longer than 35 days, bleeding longer than 8 days, no period for 90 days or more, or any change that concerns you, consult a qualified healthcare professional</string>

